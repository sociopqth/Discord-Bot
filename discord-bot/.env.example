# Discord Bot Token (required)
DISCORD_TOKEN=your_bot_token_here

# Discord Application Client ID (required for deploy-commands.js)
CLIENT_ID=your_client_id_here

# Discord Guild ID (optional: for guild-specific command deployment during dev)
GUILD_ID=your_guild_id_here

# OpenAI API Key (required for /chat command)
OPENAI_API_KEY=your_openai_key_here

# Welcome channel name (default: general)
WELCOME_CHANNEL=welcome

# Ticket category name (default: Tickets)
TICKET_CATEGORY=Tickets

# Log channel name for mod actions (default: mod-logs)
MOD_LOG_CHANNEL=mod-logs
